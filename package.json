{
  "name": "@craftzdog/fs-plus",
  "version": "4.0.4",
  "description": "node's fs with more helpers",
  "main": "./lib/fs-plus.js",
  "types": "src/fs-plus.d.ts",
  "scripts": {
    "clean": "rm -rf lib",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "dev": "npm run clean && cross-env NODE_ENV=development cross-env rollup -c -w",
    "build": "npm run clean && cross-env NODE_ENV=production cross-env rollup -c ",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craftzdog/fs-plus.git"
  },
  "bugs": {
    "url": "https://github.com/craftzdog/fs-plus/issues"
  },
  "homepage": "https://github.com/craftzdog/fs-plus",
  "license": "MIT",
  "keywords": [
    "fs",
    "filesystem"
  ],
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "rollup": "^4.60.1",
    "temp": "^0.9.4"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/spec/**/*-spec.js"
    ],
    "transform": {}
  },
  "dependencies": {
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.3"
  }
}
